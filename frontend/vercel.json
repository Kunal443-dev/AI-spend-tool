{
  "cleanUrls": true,
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "https://YOUR_BACKEND_URL/api/:path*"
    },
    {
      "source": "/report/:path*",
      "destination": "/index.html"
    },
    {
      "source": "/((?!assets/|favicon.ico|data:).*)",
      "destination": "/index.html"
    }
  ]
}
